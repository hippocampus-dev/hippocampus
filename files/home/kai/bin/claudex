#!/usr/bin/env bash

set -eo pipefail

UNIT_NAME="claudex-$$"

if [ -n "$TMUX" ]; then
  tmux setw monitor-silence 3
fi

WORKING_DIRECTORY=$(pwd)

args=()
LOCAL_MEMORY_FILE=""
while (( $# )); do
  case "$1" in
    --local-memory-file)
      LOCAL_MEMORY_FILE="$2"
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

cleanup() {
  if [ -n "$TMUX" ]; then
    tmux setw monitor-silence 0
  fi
  if [ -n "$LOCAL_MEMORY_FILE" ]; then
    rm -f ./CLAUDE.local.md
  fi
}

trap cleanup EXIT

if [ -n "$LOCAL_MEMORY_FILE" ] && [ -f "$LOCAL_MEMORY_FILE" ]; then
  cp "$LOCAL_MEMORY_FILE" ./CLAUDE.local.md
fi

paths=()
for path in \
  "BindPaths=/tmp/tmux-$(id -u)" \
  "ReadWritePaths=$WORKING_DIRECTORY" \
  "ReadWritePaths=${HOME}/.asdf" \
  "ReadWritePaths=${HOME}/.npm" \
  "ReadWritePaths=${HOME}/.cargo" \
  "ReadWritePaths=${HOME}/.rustup" \
  "ReadWritePaths=${HOME}/.gradle" \
  "ReadWritePaths=${HOME}/.android" \
  "ReadWritePaths=${HOME}/.cache" \
  "ReadWritePaths=${HOME}/.local/bin" \
  "ReadWritePaths=${HOME}/.local/share" \
  "ReadWritePaths=${HOME}/.local/state" \
  "ReadWritePaths=${HOME}/brain" \
  "ReadWritePaths=${HOME}/.config/claudex" \
  "ReadWritePaths=${HOME}/.codex" \
  "ReadWritePaths=${HOME}/.gemini" \
  "ReadWritePaths=${HOME}/.docker/buildx" \
  "ReadWritePaths=${HOME}/.kube" \
  "ReadWritePaths=/opt/hippocampus/files/${HOME}/.config/claudex/config/settings.json" \
  "ReadWritePaths=/opt/hippocampus/target" \
  "InaccessiblePaths=${HOME}/.secrets" \
  "InaccessiblePaths=${HOME}/.vault" \
  "InaccessiblePaths=${HOME}/.ssh" \
  "InaccessiblePaths=${HOME}/.gnupg" \
  "InaccessiblePaths=/etc/passwd" \
  "InaccessiblePaths=/etc/shadow" \
  "InaccessiblePaths=/run/user/$(id -u)/libvirt" \
; do
  [ -e "${path#*=}" ] && paths+=(-p "$path")
done

systemd-run \
  --unit="$UNIT_NAME" \
  --user \
  --pipe \
  --wait \
  --collect \
  --same-dir \
  -E CLAUDE_CODE_OAUTH_TOKEN="" \
  -E CLAUDE_CONFIG_DIR="${HOME}/.config/claudex/config" \
  -E PATH="$PATH" \
  -E GOPATH="/tmp" \
  -E TMUX="$TMUX" \
  -E TMUX_PANE="$TMUX_PANE" \
  -E BROWSER="${HOME}/bin/tmux-xdg-open" \
  "${paths[@]}" \
  `#-p AppArmorProfile=claude` \
  -p ProtectProc=invisible \
  -p ProcSubset=pid \
  -p NoNewPrivileges=yes \
  -p ProtectSystem=strict \
  -p ProtectHome=read-only \
  -p ReadOnlyDirectories="/opt/hippocampus/.git" \
  -p PrivateTmp=yes \
  -p PrivateDevices=yes \
  -p PrivateNetwork=no \
  -p PrivateUsers=yes \
  -p PrivateMounts=yes \
  -p ProtectKernelTunables=yes \
  -p ProtectKernelModules=yes \
  -p ProtectKernelLogs=yes \
  -p ProtectControlGroups=yes \
  -p ProtectHostname=yes \
  -p ProtectClock=yes \
  -p DevicePolicy=closed \
  -p DeviceAllow="/dev/null rw" \
  -p DeviceAllow="/dev/random r" \
  -p DeviceAllow="/dev/urandom r" \
  -p PrivateIPC=yes \
  -p RestrictNamespaces=yes \
  -p RestrictRealtime=yes \
  -p RestrictSUIDSGID=yes \
  -p LockPersonality=yes \
  -p MemoryDenyWriteExecute=no \
  -p SystemCallArchitectures=native \
  -p SystemCallFilter="@system-service" \
  -p SystemCallFilter="~@privileged @debug" \
  -p SystemCallErrorNumber=EPERM \
  -p RestrictAddressFamilies="AF_UNIX AF_INET AF_INET6 AF_VSOCK" \
  -p CapabilityBoundingSet="" \
  -p AmbientCapabilities="" \
  -p UMask=0077 \
  -p CoredumpFilter=0 \
  -p IPAccounting=yes \
  -p RestrictFileSystems="btrfs tmpfs proc sysfs" \
  -p KeyringMode=private \
  -p NotifyAccess=none \
  claude "${args[@]}"
