    {
      "parameters": {
        "method": "POST",
        "url": "http://ollama:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"model\": \"gemma3:4b\", \"messages\": [{ \"role\": \"system\", \"content\": \"You are a tech news relevance classifier. Analyze the article and respond with ONLY a JSON object: {\\\"relevant\\\": true/false, \\\"summary\\\": \\\"one-line summary in Japanese\\\"}. An article is relevant if it announces breaking changes, new major releases, deprecations, security advisories, or significant new features. Ignore minor patches, community events, case studies, and marketing content.\" }, { \"role\": \"user\", \"content\": \"Title: \" + $json.title + \"\\nContent: \" + ($json.content || $json.contentSnippet || \"\").substring(0, 1000) }], \"stream\": false, \"format\": \"json\" }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000010",
      "name": "Ollama Classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [480, 600]
    },
    {
      "parameters": {
        "jsCode": "const response = JSON.parse($input.first().json.message.content);\nconst source = $('Merge').first().json;\nreturn [{ json: { ...response, title: source.title, link: source.link, source: source._feedSource || 'unknown' } }];"
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000011",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 600]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-0",
              "leftValue": "={{ $json.relevant }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000012",
      "name": "Is Relevant",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [920, 600]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "#reminders",
          "mode": "name"
        },
        "text": ":newspaper: *{{ $json.source }}*\n\n*{{ $json.title }}*\n{{ $json.summary }}\n\n{{ $json.link }}",
        "otherOptions": {}
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000013",
      "name": "Slack Notify",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [1140, 600]
    },
    {
      "parameters": {
        "mode": "append"
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000007",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [480, 400]
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => ({ json: { ...item.json, _feedSource: 'OpenAI' } }));"
      },
